{
  "name": "meebits-world",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n vite,vrm -c cyan,magenta \"vite\" \"npm run vrm-worker:dev\"",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "vrm-worker:dev": "wrangler dev --config workers/vrm-cache/wrangler.toml",
    "vrm-worker:deploy": "wrangler deploy --config workers/vrm-cache/wrangler.toml",
    "vrm:seed": "node scripts/seed-vrm-sculptures.mjs"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vercel/analytics": "^2.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "@types/node": "^24.0.0",
    "concurrently": "^9.2.0",
    "vite": "^6.4.3",
    "wrangler": "^4.24.0"
  }
}
