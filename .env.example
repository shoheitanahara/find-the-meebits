# Cloudflare Worker URL (no trailing slash).
# Production: set in Vercel → Project → Settings → Environment Variables
# Example: https://find-the-meebits-vrm.your-subdomain.workers.dev
VITE_VRM_BASE_URL=

# Optional CDN/R2 base for BGM mp3s (no trailing slash).
# When set: museum → {base}/audio/museum-bgm.mp3, club → {base}/audio/club-bgm.mp3
# Leave empty to serve from this app's /public/audio (default).
VITE_BGM_BASE_URL=

# Local dev: `npm run dev` starts Vite + VRM Worker together.
# VRM-only worker: `npm run vrm-worker:dev`
VRM_WORKER_DEV_URL=http://127.0.0.1:8787
