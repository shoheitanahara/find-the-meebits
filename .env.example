# Cloudflare Worker URL (no trailing slash).
# Production: set in Vercel → Project → Settings → Environment Variables
# Example: https://find-the-meebits-vrm.your-subdomain.workers.dev
VITE_VRM_BASE_URL=

# Local dev: wrangler dev default (npm run vrm-worker:dev)
VRM_WORKER_DEV_URL=http://127.0.0.1:8787
